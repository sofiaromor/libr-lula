$userStmt->execute([':id' => $userId]);
$user = $userStmt->fetch(PDO::FETCH_ASSOC) ?: [];

$username = trim((string) ($user['username'] ?? $_SESSION['username'] ?? 'Lectora'));
$avatar = profileAsset($user['avatar'] ?? $_SESSION['avatar'] ?? '', 'images/avatar/avatar1.png');

if ($avatar === 'default.jpg' || str_ends_with($avatar, '/default.jpg')) {
    $avatar = 'images/avatar/avatar1.png';
}

$_SESSION['username'] = $username;
$_SESSION['avatar'] = $avatar;
$_SESSION['bio'] = $user['bio'] ?? null;

$statsStmt = $db->prepare(<<<'SQL'
    SELECT
        SUM(CASE WHEN ub.status = 'completed' THEN 1 ELSE 0 END) AS completed,
        SUM(CASE WHEN ub.score = 5 THEN 1 ELSE 0 END) AS favorites,
        SUM(CASE WHEN ub.status = 'completed' THEN COALESCE(b.pages, 0) ELSE 0 END) AS pages_read
    FROM user_books ub
    INNER JOIN books b ON b.id = ub.book_id
    WHERE ub.user_id = :user_id
SQL);
$statsStmt->execute([':user_id' => $userId]);
$stats = $statsStmt->fetch(PDO::FETCH_ASSOC) ?: [];

try {
    librelulaInitializeProfileFavorites($db, $userId);
} catch (Throwable) {
    // El perfil sigue siendo usable aunque la base de datos aún no permita crear las tablas.
}

$favoriteBooks = [];
$favoriteAuthors = [];

try {
    $favoriteStmt = $db->prepare(<<<'SQL'
        SELECT b.id, b.title, b.author, b.cover
        FROM profile_favorite_books pf
        INNER JOIN books b ON b.id = pf.book_id
        WHERE pf.user_id = :user_id
        ORDER BY pf.sort_order ASC, pf.created_at ASC
        LIMIT 6
    SQL);
    $favoriteStmt->execute([':user_id' => $userId]);
    $favoriteBooks = $favoriteStmt->fetchAll(PDO::FETCH_ASSOC);

    $favoriteAuthorStmt = $db->prepare(<<<'SQL'
        SELECT author_name
        FROM profile_favorite_authors
        WHERE user_id = :user_id
        ORDER BY sort_order ASC, created_at ASC
        LIMIT 6
    SQL);
    $favoriteAuthorStmt->execute([':user_id' => $userId]);
    $favoriteAuthors = array_map(
        static fn (mixed $value): string => trim((string) $value),
        $favoriteAuthorStmt->fetchAll(PDO::FETCH_COLUMN)
    );
} catch (PDOException) {
    // Las tablas se crean automáticamente al volver a cargar o ejecutar la migración.
}


$currentReadingStmt = $db->prepare(<<<'SQL'
    SELECT
        b.id,
        b.title,
        b.author,
        b.cover,
        b.pages,
        ub.progress,
        ub.score,
        ub.notes,
        ub.started_at,
        ub.status,
        ub.read_count
    FROM user_books ub
    INNER JOIN books b ON b.id = ub.book_id
    WHERE ub.user_id = :user_id
      AND ub.status IN ('reading', 'rereading')
    ORDER BY COALESCE(ub.started_at, '0000-00-00') DESC, ub.id DESC
    LIMIT 4
SQL);
$currentReadingStmt->execute([':user_id' => $userId]);
$currentReadingBooks = $currentReadingStmt->fetchAll(PDO::FETCH_ASSOC);

$recentActivityStmt = $db->prepare(<<<'SQL'
    SELECT
        b.id,
        b.title,
        b.author,
        b.cover,
        ub.status,
        ub.progress,
        ub.started_at,
        ub.finished_at,
        ub.paused_at,
        ub.dropped_at
    FROM user_books ub
    INNER JOIN books b ON b.id = ub.book_id
    WHERE ub.user_id = :user_id
    ORDER BY
        CASE
            WHEN ub.status = 'completed' THEN COALESCE(ub.finished_at, ub.started_at, '0000-00-00')
            WHEN ub.status = 'paused' THEN COALESCE(ub.paused_at, ub.started_at, '0000-00-00')
            WHEN ub.status = 'dropped' THEN COALESCE(ub.dropped_at, ub.started_at, '0000-00-00')
            ELSE COALESCE(ub.started_at, ub.finished_at, '0000-00-00')
        END DESC,
        ub.id DESC
    LIMIT 7
SQL);
$recentActivityStmt->execute([':user_id' => $userId]);
$recentActivity = $recentActivityStmt->fetchAll(PDO::FETCH_ASSOC);

$recentCoverPreloads = [];
$recentCoverOrigins = [];

foreach (array_slice($recentActivity, 0, 6) as $activityRow) {
    $coverUrl = profileCover($activityRow['cover'] ?? '');

    if ($coverUrl === '' || in_array($coverUrl, $recentCoverPreloads, true)) {
        continue;
    }

    $recentCoverPreloads[] = $coverUrl;

    if (preg_match('~^https?://~i', $coverUrl)) {
        $parts = parse_url($coverUrl);
        $scheme = (string) ($parts['scheme'] ?? '');
        $host = (string) ($parts['host'] ?? '');

        if ($scheme !== '' && $host !== '') {
            $origin = $scheme . '://' . $host;

            if (!in_array($origin, $recentCoverOrigins, true)) {
                $recentCoverOrigins[] = $origin;
            }
        }
    }
}

$genreStmt = $db->prepare(<<<'SQL'
    SELECT b.genre
    FROM user_books ub
    INNER JOIN books b ON b.id = ub.book_id
    WHERE ub.user_id = :user_id
SQL);
$genreStmt->execute([':user_id' => $userId]);
$genreCounts = [];

foreach ($genreStmt->fetchAll(PDO::FETCH_ASSOC) as $row) {
    $genre = librelulaNormalizeGenre($row['genre'] ?? '');

    if ($genre === '') {
        continue;
    }

    $key = function_exists('mb_strtolower')
        ? mb_strtolower($genre, 'UTF-8')
        : strtolower($genre);

    if (!isset($genreCounts[$key])) {
        $genreCounts[$key] = ['name' => $genre, 'count' => 0];
    }

    $genreCounts[$key]['count']++;
}

uasort(
    $genreCounts,
    static fn (array $left, array $right): int =>
        ($right['count'] <=> $left['count']) ?: strcasecmp((string) $left['name'], (string) $right['name'])
);
$favoriteGenres = array_slice(array_values($genreCounts), 0, 5);
$genreTotal = array_sum(array_map(static fn (array $genre): int => (int) $genre['count'], $favoriteGenres));

$today = new DateTimeImmutable('today');
$activityStart = $today->sub(new DateInterval('P181D'));
$activityPoints = [];

try {
    $activityStmt = $db->prepare(<<<'SQL'
        SELECT activity_date, points
        FROM reading_activity
        WHERE user_id = :user_id
          AND activity_date BETWEEN :start_date AND :end_date
        ORDER BY activity_date ASC
    SQL);
    $activityStmt->execute([
        ':user_id' => $userId,
        ':start_date' => $activityStart->format('Y-m-d'),
        ':end_date' => $today->format('Y-m-d'),
    ]);

    foreach ($activityStmt->fetchAll(PDO::FETCH_ASSOC) as $row) {
        $activityPoints[(string) $row['activity_date']] = max(0, (int) $row['points']);
    }
} catch (PDOException) {
    // El instalador crea reading_activity. Este fallback mantiene el perfil usable
    // incluso si la migración todavía no se ha ejecutado.
    $fallbackStmt = $db->prepare(<<<'SQL'
        SELECT started_at, finished_at
        FROM user_books
        WHERE user_id = :user_id
    SQL);
    $fallbackStmt->execute([':user_id' => $userId]);

    foreach ($fallbackStmt->fetchAll(PDO::FETCH_ASSOC) as $row) {
        foreach ([['started_at', 1], ['finished_at', 3]] as [$field, $points]) {
            $date = trim((string) ($row[$field] ?? ''));
            if ($date !== '') {
                $activityPoints[$date] = ($activityPoints[$date] ?? 0) + $points;
            }
        }
    }
}

$activityDays = [];
$cursor = $activityStart;
while ($cursor <= $today) {
    $dateKey = $cursor->format('Y-m-d');
    $points = (int) ($activityPoints[$dateKey] ?? 0);
    $activityDays[] = [
        'date' => $dateKey,
        'label' => $cursor->format('d/m/Y'),
        'points' => $points,
        'level' => profileActivityLevel($points),
    ];
    $cursor = $cursor->add(new DateInterval('P1D'));
}

$activeDateKeys = array_keys(array_filter($activityPoints, static fn (int $points): bool => $points > 0));
sort($activeDateKeys);
$streak = 0;

if ($activeDateKeys !== []) {
    $latest = new DateTimeImmutable(end($activeDateKeys));
    $yesterday = $today->sub(new DateInterval('P1D'));

    if ($latest == $today || $latest == $yesterday) {
        $streakCursor = $latest;

        while (($activityPoints[$streakCursor->format('Y-m-d')] ?? 0) > 0) {
            $streak++;
            $streakCursor = $streakCursor->sub(new DateInterval('P1D'));
        }
    }
}

$genreColors = ['#66C23A', '#20A8E8', '#8955E8', '#ED6D93', '#F59E42'];
$csrfToken = librelulaCsrfToken();
?>
