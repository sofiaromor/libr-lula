<div class="reading-completion-modal" id="reading-completion-modal" hidden>
  <button class="completion-modal-backdrop" type="button" data-completion-close aria-label="Cerrar ventana"></button>
  <section class="completion-modal-card" role="dialog" aria-modal="true" aria-labelledby="completion-title" aria-describedby="completion-copy">
    <div class="completion-celebration" aria-hidden="true">✦</div>
    <p class="completion-kicker">Lectura completada</p>
    <h2 id="completion-title">¡Enhorabuena!</h2>
    <p id="completion-copy">Has terminado <strong class="js-completion-book-title"></strong>. ¿Quieres puntuarlo y dejar una reseña?</p>

    <fieldset class="completion-rating">
      <legend>Tu puntuación</legend>
      <div class="completion-stars" role="group" aria-label="Puntuación de una a cinco estrellas">
        <?php for ($star = 1; $star <= 5; $star++): ?>
          <button type="button" class="completion-star js-completion-star" data-score="<?= $star ?>" aria-label="<?= $star ?> <?= $star === 1 ? 'estrella' : 'estrellas' ?>" aria-pressed="false">★</button>
        <?php endfor; ?>
      </div>
      <span class="completion-rating-label js-completion-rating-label">Sin puntuación</span>
    </fieldset>

    <label class="completion-review">
      <span>Tu reseña <small>(opcional)</small></span>
      <textarea class="js-completion-review" maxlength="5000" rows="5" placeholder="¿Qué te ha parecido?"></textarea>
    </label>

    <p class="completion-error js-completion-error" role="alert"></p>

    <div class="completion-actions">
      <button class="completion-secondary js-completion-later" type="button">Ahora no</button>
      <button class="completion-primary js-completion-save" type="button">Guardar valoración</button>
    </div>
  </section>
</div>

<script>
(() => {
  'use strict';

  const csrfToken = <?= json_encode($csrfToken, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
  const endpoint = 'API/user_book.php';
  const cards = [...document.querySelectorAll('.js-reading-card')];
  const modal = document.getElementById('reading-completion-modal');
  const modalTitle = modal?.querySelector('.js-completion-book-title');
  const modalReview = modal?.querySelector('.js-completion-review');
  const modalError = modal?.querySelector('.js-completion-error');
  const modalSave = modal?.querySelector('.js-completion-save');
  const modalLater = modal?.querySelector('.js-completion-later');
  const ratingLabel = modal?.querySelector('.js-completion-rating-label');
  const starButtons = [...(modal?.querySelectorAll('.js-completion-star') ?? [])];
  let activeCard = null;
  let selectedScore = null;
  let lastFocusedElement = null;

  const clamp = (value) => Math.max(0, Math.min(100, Math.round(Number(value) || 0)));

  function decodeNotes(card) {
    try {
      return decodeURIComponent(card.dataset.notesEncoded || '');
    } catch {
      return '';
    }
  }

  function setStatus(card, message = '', type = '') {
    const status = card.querySelector('.js-progress-status');
    if (!status) return;
    status.textContent = message;
    status.className = `reading-progress-status js-progress-status${type ? ` is-${type}` : ''}`;
  }

  function updateProgressUI(card, value, markDirty = true) {
    const progress = clamp(value);
    const range = card.querySelector('.js-progress-range');
    const number = card.querySelector('.js-progress-number');
    const valueLabel = card.querySelector('.js-progress-value');
    const pagesLabel = card.querySelector('.js-progress-pages');
    const saveButton = card.querySelector('.js-progress-save');
    const pages = Number(card.dataset.pages || 0);

    if (range) {
      range.value = String(progress);
      range.style.setProperty('--progress', `${progress}%`);
      range.setAttribute('aria-valuenow', String(progress));
    }
    if (number) number.value = String(progress);
    if (valueLabel) valueLabel.textContent = `${progress} %`;

    if (pagesLabel && pages > 0) {
      const readPages = Math.round((pages * progress) / 100);
      pagesLabel.textContent = `${readPages} de ${pages} páginas`;
    }

    if (saveButton && markDirty) {
      saveButton.disabled = false;
      saveButton.textContent = progress === 100 ? 'Terminar libro' : 'Guardar';
    }

    card.classList.toggle('is-completing', progress === 100);
    setStatus(card, progress === 100 ? 'Al guardar se marcará como leído.' : '');
  }

  async function postUserBook(payload) {
    const response = await fetch(endpoint, {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': csrfToken,
      },
      body: JSON.stringify(payload),
    });

    const text = await response.text();
    let data = {};

    try {
      data = text ? JSON.parse(text) : {};
    } catch {
      throw new Error('El servidor no devolvió una respuesta válida.');
    }

    if (!response.ok || data.error) {
      throw new Error(data.error || 'No se pudo guardar el progreso.');
    }

    return data;
  }

  function currentPayload(card, progress) {
    const scoreValue = card.dataset.score;

    return {
      book_id: card.dataset.bookId,
      status: progress >= 100
        ? 'completed'
        : (card.dataset.status === 'rereading' ? 'rereading' : 'reading'),
      progress,
      score: scoreValue === '' || scoreValue === undefined ? null : Number(scoreValue),
      notes: decodeNotes(card) || null,
    };
  }

  function setRating(score) {
    selectedScore = score;
    starButtons.forEach((button) => {
      const buttonScore = Number(button.dataset.score);
      button.classList.toggle('is-filled', score !== null && buttonScore <= score);
      button.setAttribute('aria-pressed', String(score === buttonScore));
    });
    if (ratingLabel) {
      ratingLabel.textContent = score === null
        ? 'Sin puntuación'
        : `${score} ${score === 1 ? 'estrella' : 'estrellas'}`;
    }
  }

  function openCompletionModal(card) {
    if (!modal) return;
    activeCard = card;
    lastFocusedElement = document.activeElement;
    const existingScore = card.dataset.score === '' ? null : Number(card.dataset.score);
    setRating(Number.isFinite(existingScore) ? existingScore : null);
    if (modalTitle) modalTitle.textContent = card.dataset.bookTitle || 'este libro';
    if (modalReview) modalReview.value = decodeNotes(card);
    if (modalError) modalError.textContent = '';
    modal.hidden = false;
    document.body.classList.add('completion-modal-open');
    window.requestAnimationFrame(() => {
      modal.classList.add('is-open');
      (starButtons[0] || modalReview || modalLater)?.focus();
    });
  }

  function closeCompletionModal({ reload = true } = {}) {
    if (!modal) return;
    modal.classList.remove('is-open');
    document.body.classList.remove('completion-modal-open');
    window.setTimeout(() => {
      modal.hidden = true;
      activeCard = null;
      if (reload) {
        window.location.reload();
      } else if (lastFocusedElement instanceof HTMLElement) {
        lastFocusedElement.focus();
      }
    }, 160);
  }

  async function saveProgress(card) {
    const progress = clamp(card.querySelector('.js-progress-number')?.value ?? card.dataset.progress);
    const saveButton = card.querySelector('.js-progress-save');
    const oldLabel = saveButton?.textContent || 'Guardar';

    if (saveButton) {
      saveButton.disabled = true;
      saveButton.textContent = 'Guardando…';
    }
    setStatus(card, 'Guardando progreso…');

    try {
      const data = await postUserBook(currentPayload(card, progress));
      const saved = data.user || {};
      card.dataset.progress = String(saved.progress ?? progress);
      card.dataset.score = saved.score === null || saved.score === undefined ? '' : String(saved.score);
      card.dataset.notesEncoded = encodeURIComponent(saved.notes || '');
      updateProgressUI(card, saved.progress ?? progress, false);

      if (progress >= 100) {
        setStatus(card, '¡Libro terminado!', 'success');
        openCompletionModal(card);
      } else {
        setStatus(card, 'Progreso guardado.', 'success');
        if (saveButton) saveButton.textContent = 'Guardado ✓';
        window.setTimeout(() => {
          if (saveButton) {
            saveButton.textContent = 'Guardar';
            saveButton.disabled = true;
          }
          setStatus(card, '');
        }, 1500);
      }
    } catch (error) {
      setStatus(card, error instanceof Error ? error.message : 'No se pudo guardar.', 'error');
      if (saveButton) {
        saveButton.disabled = false;
        saveButton.textContent = oldLabel;
      }
    }
  }

  cards.forEach((card) => {
    const range = card.querySelector('.js-progress-range');
    const number = card.querySelector('.js-progress-number');
    const saveButton = card.querySelector('.js-progress-save');

    updateProgressUI(card, card.dataset.progress || 0, false);
    if (saveButton) saveButton.disabled = true;

    range?.addEventListener('input', () => updateProgressUI(card, range.value));
    number?.addEventListener('input', () => updateProgressUI(card, number.value));
    number?.addEventListener('blur', () => updateProgressUI(card, number.value));

    card.querySelectorAll('.js-progress-step').forEach((button) => {
      button.addEventListener('click', () => {
        const current = Number(number?.value ?? range?.value ?? 0);
        updateProgressUI(card, current + Number(button.dataset.step || 0));
      });
    });

    saveButton?.addEventListener('click', () => saveProgress(card));
  });

  starButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const score = Number(button.dataset.score);
      setRating(selectedScore === score ? null : score);
    });
  });

  modalSave?.addEventListener('click', async () => {
    if (!activeCard) return;
    modalSave.disabled = true;
    modalSave.textContent = 'Guardando…';
    if (modalError) modalError.textContent = '';

    try {
      const payload = currentPayload(activeCard, 100);
      payload.status = 'completed';
      payload.progress = 100;
      payload.score = selectedScore;
      payload.notes = modalReview?.value.trim() || null;
      const data = await postUserBook(payload);
      const saved = data.user || {};
      activeCard.dataset.score = saved.score === null || saved.score === undefined ? '' : String(saved.score);
      activeCard.dataset.notesEncoded = encodeURIComponent(saved.notes || '');
      modalSave.textContent = '¡Guardado!';
      window.setTimeout(() => closeCompletionModal({ reload: true }), 450);
    } catch (error) {
      modalSave.disabled = false;
      modalSave.textContent = 'Guardar valoración';
      if (modalError) modalError.textContent = error instanceof Error ? error.message : 'No se pudo guardar la valoración.';
    }
  });

  modalLater?.addEventListener('click', () => closeCompletionModal({ reload: true }));
  modal?.querySelectorAll('[data-completion-close]').forEach((button) => {
    button.addEventListener('click', () => closeCompletionModal({ reload: true }));
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && modal && !modal.hidden) {
      closeCompletionModal({ reload: true });
    }
  });
})();
</script>


<script>
(() => {
  'use strict';

  const modal = document.getElementById('profile-favorites-modal');
  const openButtons = [...document.querySelectorAll('.js-edit-favorites')];
  const closeButtons = [...(modal?.querySelectorAll('[data-favorites-close]') ?? [])];
  const bookSearch = modal?.querySelector('.js-favorite-book-search');
  const authorSearch = modal?.querySelector('.js-favorite-author-search');
  const bookResults = modal?.querySelector('.js-favorite-book-results');
  const authorResults = modal?.querySelector('.js-favorite-author-results');
  const selectedBooksNode = modal?.querySelector('.js-selected-books');
  const selectedAuthorsNode = modal?.querySelector('.js-selected-authors');
  const bookCount = modal?.querySelector('.js-selected-books-count');
  const authorCount = modal?.querySelector('.js-selected-authors-count');
  const saveButton = modal?.querySelector('.js-save-favorites');
  const statusNode = modal?.querySelector('.js-favorites-modal-status');
  const endpoint = 'API/profile_favorites.php';
  const csrfToken = <?= json_encode($csrfToken, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES) ?>;
  const initialBooks = <?= json_encode(array_map(static fn (array $book): array => [
      'id' => (string) $book['id'],
      'title' => (string) $book['title'],
      'author' => (string) $book['author'],
      'cover' => profileCover($book['cover'] ?? ''),
  ], $favoriteBooks), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;
  const initialAuthors = <?= json_encode(array_values($favoriteAuthors), JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?>;

  if (!modal) return;

  let selectedBooks = new Map(initialBooks.map((book) => [String(book.id), book]));
  let selectedAuthors = [...initialAuthors];
  let lastFocused = null;
  let bookTimer = null;
  let authorTimer = null;

  const element = (tag, className = '', text = '') => {
    const node = document.createElement(tag);
    if (className) node.className = className;
    if (text) node.textContent = text;
    return node;
  };

  function setStatus(message = '', type = '') {
    if (!statusNode) return;
    statusNode.textContent = message;
    statusNode.className = `favorites-modal-status js-favorites-modal-status${type ? ` is-${type}` : ''}`;
  }

  function bookCover(book) {
    const wrapper = element('span', 'favorite-editor-cover');
    wrapper.textContent = (book.title || 'L').trim().charAt(0).toUpperCase() || 'L';
    if (book.cover) {
      const image = document.createElement('img');
      image.src = book.cover;
      image.alt = '';
      image.addEventListener('error', () => image.remove());
      wrapper.append(image);
    }
    return wrapper;
  }

  function renderSelectedBooks() {
    if (!selectedBooksNode || !bookCount) return;
    selectedBooksNode.replaceChildren();
    bookCount.textContent = `${selectedBooks.size}/6`;

    if (selectedBooks.size === 0) {
      selectedBooksNode.append(element('p', 'favorites-editor-empty', 'No has seleccionado ningún libro.'));
      return;
    }

    selectedBooks.forEach((book, id) => {
      const item = element('article', 'favorite-selected-item');
      item.append(bookCover(book));
      const copy = element('div', 'favorite-selected-copy');
      copy.append(element('strong', '', book.title || 'Sin título'));
      copy.append(element('span', '', book.author || 'Autor desconocido'));
      item.append(copy);
      const remove = element('button', 'favorite-remove-button', '×');
      remove.type = 'button';
      remove.setAttribute('aria-label', `Quitar ${book.title || 'libro'}`);
      remove.addEventListener('click', () => {
        selectedBooks.delete(id);
        renderSelectedBooks();
        if (bookSearch?.value.trim()) searchBooks(bookSearch.value.trim());
      });
      item.append(remove);
      selectedBooksNode.append(item);
    });
  }

  function renderSelectedAuthors() {
    if (!selectedAuthorsNode || !authorCount) return;
    selectedAuthorsNode.replaceChildren();
    authorCount.textContent = `${selectedAuthors.length}/6`;

    if (selectedAuthors.length === 0) {
      selectedAuthorsNode.append(element('p', 'favorites-editor-empty', 'No has seleccionado ningún autor.'));
      return;
    }

    selectedAuthors.forEach((author) => {
      const item = element('article', 'favorite-selected-item favorite-selected-author');
      const initial = element('span', 'favorite-editor-author-initial', author.trim().charAt(0).toUpperCase() || 'A');
      item.append(initial);
      item.append(element('strong', '', author));
      const remove = element('button', 'favorite-remove-button', '×');
      remove.type = 'button';
      remove.setAttribute('aria-label', `Quitar ${author}`);
      remove.addEventListener('click', () => {
        selectedAuthors = selectedAuthors.filter((value) => value.toLocaleLowerCase() !== author.toLocaleLowerCase());
        renderSelectedAuthors();
        if (authorSearch?.value.trim()) searchAuthors(authorSearch.value.trim());
      });
      item.append(remove);
      selectedAuthorsNode.append(item);
    });
  }

  async function getResults(type, query) {
    const response = await fetch(`${endpoint}?type=${encodeURIComponent(type)}&q=${encodeURIComponent(query)}`, {
      credentials: 'same-origin',
      headers: { Accept: 'application/json' },
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok || data.error) throw new Error(data.error || 'No se pudo buscar.');
    return data;
  }

  async function searchBooks(query) {
    if (!bookResults) return;
    if (query.length < 2) {
      bookResults.replaceChildren(element('p', 'favorites-search-hint', 'Escribe al menos 2 letras.'));
      return;
    }
    bookResults.replaceChildren(element('p', 'favorites-search-hint', 'Buscando…'));
    try {
      const data = await getResults('books', query);
      bookResults.replaceChildren();
      const books = data.books || [];
      if (books.length === 0) {
        bookResults.append(element('p', 'favorites-search-hint', 'No se encontraron libros.'));
        return;
      }
      books.forEach((book) => {
        const id = String(book.id);
        const selected = selectedBooks.has(id);
        const button = element('button', `favorite-search-result${selected ? ' is-selected' : ''}`);
        button.type = 'button';
        button.disabled = selected || (!selected && selectedBooks.size >= 6);
        button.append(bookCover(book));
        const copy = element('span', 'favorite-search-copy');
        copy.append(element('strong', '', book.title || 'Sin título'));
        copy.append(element('small', '', book.author || 'Autor desconocido'));
        button.append(copy);
        button.append(element('span', 'favorite-search-action', selected ? 'Elegido' : 'Añadir'));
        button.addEventListener('click', () => {
          if (selectedBooks.size >= 6 || selectedBooks.has(id)) return;
          selectedBooks.set(id, book);
          renderSelectedBooks();
          searchBooks(query);
        });
        bookResults.append(button);
      });
    } catch (error) {
      bookResults.replaceChildren(element('p', 'favorites-search-error', error instanceof Error ? error.message : 'No se pudo buscar.'));
    }
  }

  async function searchAuthors(query) {
    if (!authorResults) return;
    if (query.length < 2) {
      authorResults.replaceChildren(element('p', 'favorites-search-hint', 'Escribe al menos 2 letras.'));
      return;
    }
    authorResults.replaceChildren(element('p', 'favorites-search-hint', 'Buscando…'));
    try {
      const data = await getResults('authors', query);
      authorResults.replaceChildren();
      const authors = data.authors || [];
      if (authors.length === 0) {
        authorResults.append(element('p', 'favorites-search-hint', 'No se encontraron autores.'));
        return;
      }
      authors.forEach((item) => {
        const author = String(item.author_name || '').trim();
        const selected = selectedAuthors.some((value) => value.toLocaleLowerCase() === author.toLocaleLowerCase());
        const button = element('button', `favorite-search-result author-result${selected ? ' is-selected' : ''}`);
        button.type = 'button';
        button.disabled = selected || (!selected && selectedAuthors.length >= 6);
        button.append(element('span', 'favorite-editor-author-initial', author.charAt(0).toUpperCase() || 'A'));
        const copy = element('span', 'favorite-search-copy');
        copy.append(element('strong', '', author));
        copy.append(element('small', '', `${Number(item.book_count || 0)} libros en el catálogo`));
        button.append(copy);
        button.append(element('span', 'favorite-search-action', selected ? 'Elegido' : 'Añadir'));
        button.addEventListener('click', () => {
          if (selectedAuthors.length >= 6 || selected) return;
          selectedAuthors.push(author);
          renderSelectedAuthors();
          searchAuthors(query);
        });
        authorResults.append(button);
      });
    } catch (error) {
      authorResults.replaceChildren(element('p', 'favorites-search-error', error instanceof Error ? error.message : 'No se pudo buscar.'));
    }
  }

  function openModal() {
    lastFocused = document.activeElement;
    selectedBooks = new Map(initialBooks.map((book) => [String(book.id), { ...book }]));
    selectedAuthors = [...initialAuthors];
    renderSelectedBooks();
    renderSelectedAuthors();
    if (bookResults) bookResults.replaceChildren(element('p', 'favorites-search-hint', 'Busca libros para añadirlos.'));
    if (authorResults) authorResults.replaceChildren(element('p', 'favorites-search-hint', 'Busca autores para añadirlos.'));
    if (bookSearch) bookSearch.value = '';
    if (authorSearch) authorSearch.value = '';
    setStatus();
    modal.hidden = false;
    document.body.classList.add('profile-modal-open');
    window.requestAnimationFrame(() => {
      modal.classList.add('is-open');
      bookSearch?.focus();
    });
  }

  function closeModal() {
    modal.classList.remove('is-open');
    document.body.classList.remove('profile-modal-open');
    window.setTimeout(() => {
      modal.hidden = true;
      if (lastFocused instanceof HTMLElement) lastFocused.focus();
    }, 150);
  }

  openButtons.forEach((button) => button.addEventListener('click', openModal));
  closeButtons.forEach((button) => button.addEventListener('click', closeModal));

  bookSearch?.addEventListener('input', () => {
    window.clearTimeout(bookTimer);
    bookTimer = window.setTimeout(() => searchBooks(bookSearch.value.trim()), 250);
  });
  authorSearch?.addEventListener('input', () => {
    window.clearTimeout(authorTimer);
    authorTimer = window.setTimeout(() => searchAuthors(authorSearch.value.trim()), 250);
  });

  saveButton?.addEventListener('click', async () => {
    saveButton.disabled = true;
    saveButton.textContent = 'Guardando…';
    setStatus('Guardando tus favoritos…');
    try {
      const response = await fetch(endpoint, {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken,
        },
        body: JSON.stringify({
          book_ids: [...selectedBooks.keys()],
          authors: selectedAuthors,
        }),
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || data.error) throw new Error(data.error || 'No se pudieron guardar tus favoritos.');
      setStatus('Favoritos guardados.', 'success');
      saveButton.textContent = '¡Guardado!';
      window.setTimeout(() => window.location.reload(), 450);
    } catch (error) {
      saveButton.disabled = false;
      saveButton.textContent = 'Guardar favoritos';
      setStatus(error instanceof Error ? error.message : 'No se pudieron guardar tus favoritos.', 'error');
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !modal.hidden) closeModal();
  });
})();
</script>

</body>
</html>
