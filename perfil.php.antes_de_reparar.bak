                  class="current-reading-card js-reading-card"
                  data-book-id="<?= profileEscape($bookId) ?>"
                  data-book-title="<?= profileEscape($book['title']) ?>"
                  data-book-author="<?= profileEscape($book['author']) ?>"
                  data-progress="<?= $progress ?>"
                  data-status="<?= profileEscape((string) ($book['status'] ?? 'reading')) ?>"
                  data-pages="<?= $pages ?>"
                  data-score="<?= profileEscape($bookScore) ?>"
                  data-notes-encoded="<?= profileEscape($bookNotesEncoded) ?>"
                >
                  <a class="current-reading-cover" href="catalogo/?book=<?= rawurlencode($bookId) ?>" aria-label="Abrir <?= profileEscape($book['title']) ?>">
                    <span><?= profileEscape(profileInitial((string) $book['title'])) ?></span>
                    <?php if ($cover !== ''): ?>
                      <img src="<?= profileEscape($cover) ?>" alt="Portada de <?= profileEscape($book['title']) ?>" loading="eager" fetchpriority="high" decoding="async" onerror="this.remove()">
                    <?php endif; ?>
                  </a>

                  <div class="current-reading-copy">
                    <div class="current-reading-title-row">
                      <div>
                        <h3><?= profileEscape($book['title']) ?></h3>
                        <p><?= profileEscape($book['author']) ?></p>
                      </div>
                      <span class="reading-state-chip state-<?= profileEscape((string) ($book['status'] ?? 'reading')) ?>">
                        <?= ($book['status'] ?? 'reading') === 'rereading' ? 'Releyendo' : 'Leyendo' ?>
                      </span>
                    </div>
                    <?php if ((int) ($book['read_count'] ?? 0) > 0): ?>
                      <small class="reading-times-copy">Leído <?= (int) $book['read_count'] ?> <?= (int) $book['read_count'] === 1 ? 'vez' : 'veces' ?></small>
                    <?php endif; ?>
                    <div class="reading-progress-copy">
                      <label for="<?= profileEscape($progressInputId) ?>">Progreso</label>
                      <strong class="js-progress-value"><?= $progress ?> %</strong>
                    </div>
                    <input
                      class="reading-progress-range js-progress-range"
                      id="<?= profileEscape($progressInputId) ?>"
                      type="range"
                      min="0"
                      max="100"
                      step="5"
                      value="<?= $progress ?>"
                      aria-label="Progreso de <?= profileEscape($book['title']) ?>"
                      style="--progress: <?= $progress ?>%"
                    >
                    <div class="reading-progress-actions">
                      <button class="progress-step-button js-progress-step" type="button" data-step="-5" aria-label="Restar 5 por ciento">−5</button>
                      <label class="progress-number-wrap">
                        <span class="sr-only">Porcentaje exacto</span>
                        <input class="reading-progress-number js-progress-number" type="number" min="0" max="100" step="1" value="<?= $progress ?>">
                        <span>%</span>
                      </label>
                      <button class="progress-step-button js-progress-step" type="button" data-step="5" aria-label="Sumar 5 por ciento">+5</button>
                      <button class="progress-save-button js-progress-save" type="button">Guardar</button>
                    </div>
                    <small class="js-progress-pages">
                      <?php if ($pages > 0): ?>
                        <?= $readPages ?> de <?= $pages ?> páginas
                      <?php else: ?>
                        Desde <?= profileEscape(profileDateLabel($book['started_at'] ?? null)) ?>
                      <?php endif; ?>
                    </small>
                    <p class="reading-progress-status js-progress-status" role="status" aria-live="polite"></p>
                    <a class="reading-timeline-link" href="lectura.php?book_id=<?= rawurlencode($bookId) ?>">Editar estado, fechas y timeline →</a>
                  </div>
                </article>
              <?php endforeach; ?>
            </div>
          <?php else: ?>
            <div class="profile-section-empty">
              <p>No tienes ningún libro marcado como «Leyendo».</p>
              <a href="catalogo/">Buscar mi próxima lectura →</a>
            </div>
          <?php endif; ?>
        </section>

        <section class="profile-panel recent-activity-section" id="actividad" aria-labelledby="recent-activity-title">
          <div class="panel-heading-row">
            <div>
              <p class="panel-eyebrow">Tu recorrido lector</p>
              <h2 id="recent-activity-title">Actividad reciente</h2>
            </div>
            <a class="panel-link" href="biblioteca.php">Ver biblioteca</a>
          </div>

          <?php if ($recentActivity !== []): ?>
            <ol class="recent-activity-list">
              <?php foreach ($recentActivity as $activityIndex => $activity): ?>
                <?php
                  $activityCover = profileCover($activity['cover'] ?? '');
                  $activityProgress = max(0, min(100, (int) ($activity['progress'] ?? 0)));
                  $activityDate = profileActivityDate($activity);
                ?>
                <li class="recent-activity-item">
                  <a class="activity-cover" href="catalogo/?book=<?= rawurlencode((string) $activity['id']) ?>" aria-label="Abrir <?= profileEscape($activity['title']) ?>">
                    <span><?= profileEscape(profileInitial((string) $activity['title'])) ?></span>
                    <?php if ($activityCover !== ''): ?>
                      <img
                        src="<?= profileEscape($activityCover) ?>"
                        alt=""
                        loading="<?= $activityIndex < 6 ? 'eager' : 'lazy' ?>"
                        fetchpriority="<?= $activityIndex < 4 ? 'high' : 'auto' ?>"
                        decoding="<?= $activityIndex < 4 ? 'sync' : 'async' ?>"
                        width="38"
                        height="57"
                        onload="this.classList.add('is-loaded')"
                        onerror="this.remove()"
                      >
                    <?php endif; ?>
                  </a>
                  <div class="activity-copy">
                    <p>
                      <?= profileEscape(profileActivityAction((string) $activity['status'], $activityProgress)) ?>
                      <strong><?= profileEscape($activity['title']) ?></strong>
                    </p>
                    <small>
                      <?= profileEscape(profileDateLabel($activityDate)) ?>
                      <?php if (in_array(($activity['status'] ?? ''), ['reading', 'rereading', 'paused'], true)): ?>
                        · <?= $activityProgress ?> % leído
                      <?php endif; ?>
                    </small>
                  </div>
                  <span class="activity-status-pill status-<?= profileEscape((string) ($activity['status'] ?? 'planned')) ?>">
                    <?= profileEscape(match ((string) ($activity['status'] ?? '')) {
                      'completed' => 'Leído',
                      'reading' => 'Leyendo',
                      'rereading' => 'Releyendo',
                      'paused' => 'Pausado',
                      'dropped' => 'Abandonado',
                      default => 'Pendiente',
                    }) ?>
                  </span>
                </li>
              <?php endforeach; ?>
            </ol>
          <?php else: ?>
            <div class="profile-section-empty">
              <p>Tu actividad aparecerá aquí al añadir o actualizar libros.</p>
            </div>
          <?php endif; ?>
        </section>
      </div>
    </div>
  </section>
</main>



