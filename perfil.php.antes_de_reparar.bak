$userId = (int) $_SESSION['user_id'];
librelulaReadingEnsureSchema($db);

function profileEscape(mixed $value): string
{
    return htmlspecialchars((string) $value, ENT_QUOTES, 'UTF-8');
}

function profileInitial(string $username): string
{
    $username = trim($username);

    if ($username === '') {
        return 'L';
    }

    return function_exists('mb_substr')
        ? mb_strtoupper(mb_substr($username, 0, 1, 'UTF-8'), 'UTF-8')
        : strtoupper(substr($username, 0, 1));
}

function profileMemberSince(?string $createdAt): string
{
    if (!$createdAt) {
        return 'lectora desde hace poco';
    }

    try {
        $date = new DateTimeImmutable($createdAt);
    } catch (Throwable) {
        return 'lectora desde hace poco';
    }

    $months = [
        1 => 'enero',
        2 => 'febrero',
        3 => 'marzo',
        4 => 'abril',
        5 => 'mayo',
        6 => 'junio',
        7 => 'julio',
        8 => 'agosto',
        9 => 'septiembre',
        10 => 'octubre',
        11 => 'noviembre',
        12 => 'diciembre',
    ];

    return sprintf(
        'lectora desde %s de %s',
        $months[(int) $date->format('n')] ?? '',
        $date->format('Y')
    );
}

function profileAsset(?string $path, string $fallback = ''): string
{
    $path = trim((string) $path);

    if ($path === '') {
        return $fallback;
    }

    if (preg_match('~^(?:https?:)?//|^data:~i', $path)) {
        return $path;
    }

    $normalized = ltrim(str_replace('\\', '/', $path), '/');
    $normalized = preg_replace('~^(?:\./|\.\./)*(?:librelula/)+~i', '', $normalized) ?? $normalized;

    return $normalized !== '' ? $normalized : $fallback;
}

function profileCover(?string $cover): string
{
    return profileAsset($cover);
}

/** @return list<string> */
function profileParseGenres(?string $value): array
{
    $value = trim((string) $value);

    if ($value === '' || $value === '[]') {
        return [];
    }

    if (str_starts_with($value, '[')) {
        $decoded = json_decode($value, true);

        if (is_array($decoded)) {
            $genres = [];

            foreach ($decoded as $genre) {
                $genre = trim((string) $genre);
                if ($genre !== '') {
                    $genres[] = $genre;
                }
            }

            return array_values(array_unique($genres));
        }
    }

    $genres = preg_split('/[,;|]+/u', $value) ?: [];
    $genres = array_map(static fn (string $genre): string => trim($genre), $genres);
    $genres = array_filter($genres, static fn (string $genre): bool => $genre !== '');

    return array_values(array_unique($genres));
}

function profileActivityLevel(int $points): int
{
    return match (true) {
        $points <= 0 => 0,
        $points === 1 => 1,
        $points <= 3 => 2,
        default => 3,
    };
}

function profileDateLabel(?string $value): string
{
    $value = trim((string) $value);

    if ($value === '') {
        return 'Sin fecha';
    }

    try {
        $date = new DateTimeImmutable($value);
        $today = new DateTimeImmutable('today');
        $day = $date->setTime(0, 0);

        if ($day == $today) {
            return 'Hoy';
        }

        if ($day == $today->sub(new DateInterval('P1D'))) {
            return 'Ayer';
        }

        return $date->format('d/m/Y');
    } catch (Throwable) {
        return 'Sin fecha';
    }
}

function profileActivityAction(string $status, int $progress): string
{
    return match ($status) {
        'completed' => 'Terminaste',
        'reading' => $progress > 0 ? 'Actualizaste tu progreso en' : 'Empezaste a leer',
        'rereading' => $progress > 0 ? 'Actualizaste tu relectura de' : 'Empezaste a releer',
        'paused' => 'Pausaste',
        'planned' => 'Añadiste a pendientes',
        'dropped' => 'Marcaste como abandonado',
        default => 'Actualizaste',
    };
}

function profileActivityDate(array $row): ?string
{
    return (string) match ((string) ($row['status'] ?? '')) {
        'completed' => $row['finished_at'] ?? $row['started_at'] ?? '',
        'paused' => $row['paused_at'] ?? $row['started_at'] ?? '',
        'dropped' => $row['dropped_at'] ?? $row['started_at'] ?? '',
        default => $row['started_at'] ?? $row['finished_at'] ?? '',
    };
}

