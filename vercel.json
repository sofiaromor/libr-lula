{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "catalogo",
  "redirects": [
    {
      "source": "/index.php",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/librelula/index.php",
      "destination": "/",
      "permanent": false
    }
  ]
}